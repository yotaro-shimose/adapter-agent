datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = -1
}

model Experiment {
  experiment_name String       @id
  graph_json      Json?        @default("{}")
  created_at      DateTime     @default(now())
  trajectories    Trajectory[]
  knowledges      Knowledge[]

  @@map("experiments")
}

model Trajectory {
  id                    Int        @id @default(autoincrement())
  experiment            Experiment @relation(fields: [experiment_name], references: [experiment_name], onDelete: Cascade)
  experiment_name       String
  task_id               String
  knowledge_id          String?    // Changed from Int? to String? for UUID
  instruction          String?
  conclusion           String?
  reward               Float?
  trials_json          Json?
  final_knowledge      String?
  final_knowledge_title String?
  is_sft_candidate     Boolean    @default(false)
  usage_count          Int        @default(0)
  last_used_at         DateTime   @default(now())
  created_at           DateTime   @default(now())
  citations            Citation[]

  @@map("trajectories")
  @@index([task_id])
  @@index([experiment_name])
}

model Knowledge {
  id            String       @id // Changed from Int to String for UUID
  experiment    Experiment   @relation(fields: [experiment_name], references: [experiment_name], onDelete: Cascade)
  experiment_name String
  task_id       String
  instruction   String
  title         String
  content       String
  created_at    DateTime     @default(now())
  citations     Citation[]   @relation("KnowledgeToCitation")

  @@map("knowledge_base")
  @@index([experiment_name])
}

model Citation {
  id             Int        @id @default(autoincrement())
  trajectory     Trajectory @relation(fields: [trajectory_id], references: [id], onDelete: Cascade)
  trajectory_id  Int
  knowledge_id   String     // Changed from Int? to String and made it required
  knowledge      Knowledge  @relation("KnowledgeToCitation", fields: [knowledge_id], references: [id])
  content        String?
  title          String?
  turn_index     Int        @default(0)
  created_at     DateTime   @default(now())

  @@map("citations")
}

model SimpleTrainRun {
  id              String   @id // simple_train_id
  created_at      DateTime @default(now())
  trajectories    SimpleTrajectory[]

  @@map("simple_train_runs")
}

model SimpleTrajectory {
  id              Int      @id @default(autoincrement())
  simple_train_id String
  simple_train    SimpleTrainRun @relation(fields: [simple_train_id], references: [id], onDelete: Cascade)
  
  knowledge_id    String
  knowledge_title String
  
  step            Int
  question        String
  reasoning       String
  answer          String
  success         Boolean
  
  execution_output    String?
  verification_output String?
  
  created_at      DateTime @default(now())
  
  @@map("simple_trajectories")
  @@index([simple_train_id])
  @@index([knowledge_id])
}

