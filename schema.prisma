datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = -1
}

model Experiment {
  experiment_name String       @id
  graph_json      Json?        @default("{}")
  created_at      DateTime     @default(now())
  trajectories    Trajectory[]
  knowledges      Knowledge[]

  @@map("experiments")
}

model Trajectory {
  id                    Int        @id @default(autoincrement())
  experiment            Experiment @relation(fields: [experiment_name], references: [experiment_name], onDelete: Cascade)
  experiment_name       String
  task_id               String
  knowledge_ids         String[]   @default([])
  instruction          String?
  conclusion           String?
  reward               Float?
  trials_json          Json?
  final_knowledge      String?
  final_knowledge_title String?
  is_sft_candidate     Boolean    @default(false)
  usage_count          Int        @default(0)
  last_used_at         DateTime   @default(now())
  created_at           DateTime   @default(now())

  @@map("trajectories")
  @@index([task_id])
  @@index([experiment_name])
}

model Knowledge {
  id            String       @id // Changed from Int to String for UUID
  experiment    Experiment   @relation(fields: [experiment_name], references: [experiment_name], onDelete: Cascade)
  experiment_name String
  task_id       String
  instruction   String
  title         String
  content       String
  created_at    DateTime     @default(now())

  @@map("knowledge_base")
  @@index([experiment_name])
}

model SimpleTrainRun {
  id              String   @id // simple_train_id
  created_at      DateTime @default(now())
  sft_qnas        SimpleSftQna[]
  star_qnas       StarQna[]

  @@map("simple_train_runs")
  granular_knowledges GranularKnowledge[]
}

model GranularKnowledge {
  id              String   @id @default(uuid())
  simple_train_id String
  simple_train    SimpleTrainRun @relation(fields: [simple_train_id], references: [id], onDelete: Cascade)
  
  title           String
  content         String
  
  
  created_at      DateTime @default(now())
  
  @@map("granular_knowledges")
  @@index([simple_train_id])
}

model SimpleSftQna {
  id              Int      @id @default(autoincrement())
  simple_train_id String
  simple_train    SimpleTrainRun @relation(fields: [simple_train_id], references: [id], onDelete: Cascade)

  knowledge_id    String
  knowledge_title String

  question        String
  reasoning       String
  answer          String

  created_at      DateTime @default(now())

  @@map("simple_sft_qnas")
  @@index([simple_train_id])
  @@index([knowledge_id])

}

model StarQna {
  id              Int      @id @default(autoincrement())
  simple_train_id String
  simple_train    SimpleTrainRun @relation(fields: [simple_train_id], references: [id], onDelete: Cascade)

  star_step       Int
  task_suite      String
  task_id         String   // Task.id (run 内で安定). 同一 task からの成功サンプルをグルーピングしたり均等サンプリングするための key。
  question        String
  reasoning       String
  answer          String

  created_at      DateTime @default(now())

  @@map("star_qnas")
  @@index([simple_train_id])
  @@index([simple_train_id, star_step])
  @@index([simple_train_id, task_id])
}


model WikiArticle {
  version    String
  title      String
  content    String
  updated_at DateTime @updatedAt
  created_at DateTime @default(now())

  @@id([version, title]) // Compound Primary Key
  @@map("wiki_articles")
}

model OpenBookExperiment {
  experiment_name String   @id
  created_at      DateTime @default(now())
  qnas            OpenBookQA[]
  trajectories    OpenBookTrajectory[]

  @@map("openbook_experiments")
}

model OpenBookQA {
  id              Int                @id @default(autoincrement())
  experiment_name String
  experiment      OpenBookExperiment @relation(fields: [experiment_name], references: [experiment_name], onDelete: Cascade)
  
  knowledge_id    String
  title           String
  question        String
  answer          String
  
  @@map("openbook_qnas")
  @@index([experiment_name])
}

model OpenBookTrajectory {
  id              Int                @id @default(autoincrement())
  experiment_name String
  experiment      OpenBookExperiment @relation(fields: [experiment_name], references: [experiment_name], onDelete: Cascade)

  qa_id           Int
  
  question        String
  hint            String

  reasoning       String
  answer          String
  success         Boolean
  
  execution_output    String?
  verification_output String?
  
  dataset         String?  // "train" or "holdout"
  
  @@map("openbook_trajectories")
  @@index([experiment_name])
}
