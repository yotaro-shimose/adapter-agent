datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = -1
}

model Experiment {
  experiment_name String       @id
  graph_json      Json?        @default("{}")
  created_at      DateTime     @default(now())
  trajectories    Trajectory[]
  knowledges      Knowledge[]

  @@map("experiments")
}

model Trajectory {
  id                    Int        @id @default(autoincrement())
  experiment            Experiment @relation(fields: [experiment_name], references: [experiment_name], onDelete: Cascade)
  experiment_name       String
  task_id               String
  knowledge_ids         String[]   @default([])
  instruction          String?
  conclusion           String?
  reward               Float?
  trials_json          Json?
  final_knowledge      String?
  final_knowledge_title String?
  is_sft_candidate     Boolean    @default(false)
  usage_count          Int        @default(0)
  last_used_at         DateTime   @default(now())
  created_at           DateTime   @default(now())

  @@map("trajectories")
  @@index([task_id])
  @@index([experiment_name])
}

model Knowledge {
  id            String       @id // Changed from Int to String for UUID
  experiment    Experiment   @relation(fields: [experiment_name], references: [experiment_name], onDelete: Cascade)
  experiment_name String
  task_id       String
  instruction   String
  title         String
  content       String
  created_at    DateTime     @default(now())

  @@map("knowledge_base")
  @@index([experiment_name])
}

model SimpleTrainRun {
  id              String   @id // simple_train_id
  created_at      DateTime @default(now())
  star_qnas       StarQna[]
  rl_rollouts     SimpleRlRollout[]

  @@map("simple_train_runs")
  granular_knowledges GranularKnowledge[]
}

model GranularKnowledge {
  id              String   @id @default(uuid())
  simple_train_id String
  simple_train    SimpleTrainRun @relation(fields: [simple_train_id], references: [id], onDelete: Cascade)
  
  title           String
  content         String
  
  
  created_at      DateTime @default(now())
  
  @@map("granular_knowledges")
  @@index([simple_train_id])
}

// User-named cache of generated QRAs, keyed by `id` (e.g. "PoC", "hisab_sft_v1").
// Replaces both the old per-knowledge pickle cache AND the dead `simple_sft_qnas`
// audit log — same row is now both the cache lookup and the audit.
model SftCache {
  id           String   @id
  granular_id  String?  // source granular knowledge batch
  library_name String?
  description  String?
  created_at   DateTime @default(now())
  items        SftCacheItem[]

  @@map("sft_caches")
}

model SftCacheItem {
  id              Int      @id @default(autoincrement())
  cache_id        String
  cache           SftCache @relation(fields: [cache_id], references: [id], onDelete: Cascade)

  knowledge_id    String
  knowledge_title String
  question        String
  reasoning       String   @default("")
  answer          String

  // PoC / synthesis flow only — empty for plain pickle-replacement caches.
  // `verified=true` means the answer was checked end-to-end via ss_solve_verify.
  verified           Boolean  @default(false)
  verifier_reasoning String   @default("")
  conclusion         String   @default("")
  // Multi-turn investigation log from the synthesis-solver (system/user/assistant
  // messages, tool tags & their results). Null for non-synthesis caches.
  trials_json        Json?
  reward             Float?

  created_at      DateTime @default(now())

  @@map("sft_cache_items")
  @@index([cache_id])
  @@index([knowledge_id])
}

model SimpleRlRollout {
  id                  Int      @id @default(autoincrement())
  simple_train_id     String
  simple_train        SimpleTrainRun @relation(fields: [simple_train_id], references: [id], onDelete: Cascade)

  rl_step             Int
  suite_name          String   // e.g. "knowledge_rl__title", "gh_archive_rl"
  task_id             String   // Task.id (stable within run)

  // One row per (group, sample). `sample_idx` indexes within the group.
  group_idx           Int      // 0..N for groups produced this iter
  sample_idx          Int      // 0..num_samples-1 within the group
  num_samples         Int      // group size (= rollout.num_samples)

  instruction         String
  answer              String
  reasoning           String   @default("")
  parsed              Boolean
  success             Boolean
  reward              Float
  execution_output    String
  verification_output String
  sampling_client_version Int

  created_at          DateTime @default(now())

  @@map("simple_rl_rollouts")
  @@index([simple_train_id])
  @@index([simple_train_id, rl_step])
}


model StarQna {
  id              Int      @id @default(autoincrement())
  simple_train_id String
  simple_train    SimpleTrainRun @relation(fields: [simple_train_id], references: [id], onDelete: Cascade)

  star_step       Int
  task_suite      String
  task_id         String   // Task.id (run 内で安定). 同一 task からの成功サンプルをグルーピングしたり均等サンプリングするための key。
  question        String
  reasoning       String
  answer          String

  created_at      DateTime @default(now())

  @@map("star_qnas")
  @@index([simple_train_id])
  @@index([simple_train_id, star_step])
  @@index([simple_train_id, task_id])
}


model WikiArticle {
  version    String
  title      String
  content    String
  updated_at DateTime @updatedAt
  created_at DateTime @default(now())

  @@id([version, title]) // Compound Primary Key
  @@map("wiki_articles")
}

